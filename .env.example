# Copy to .env and fill in your key(s).  .env is git-ignored — never commit real keys.

# ── Provider switch ──────────────────────────────────────────────────────────
# Which provider powers chat + embeddings:  gemini (free, default) | openai
LLM_PROVIDER=gemini
# Optional: override EMBEDDINGS only. gemini | openai | local (sentence-transformers, no API cost).
# Defaults to match LLM_PROVIDER when unset.
# EMBEDDING_PROVIDER=gemini

# ── Google Gemini (free tier) ────────────────────────────────────────────────
# Provide ONE key, or a comma-separated list for round-robin rotation
# (free tier is ~10 requests/min per key — multiple keys raise effective throughput).
GEMINI_API_KEY=your-gemini-api-key
# GEMINI_API_KEYS=key1,key2,key3
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# ── OpenAI (first-class alternative; the real client's target) ───────────────
# OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── Retrieval / chunking knobs (defaults tuned empirically on the sample corpus) ─
TOP_K=4
# Gate 1: queries whose best chunk scores below this (1 - cosine distance) get the
# not-found answer without an LLM call. Tuned so grounded questions clear it by
# a wide margin (>=0.67 observed) while off-topic ones fall below (~0.49 observed).
RELEVANCE_THRESHOLD=0.55
# Smaller chunks = topically coherent units -> better relevance separation.
CHUNK_SIZE=400
CHUNK_OVERLAP=60
EMBED_DIM=768
CHROMA_DIR=./chroma_db
